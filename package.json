{
  "name": "gcc",
  "private": true,
  "version": "6.2.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3 -c wxt.config.firefox.ts",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3 -c wxt.config.firefox.ts",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3 -c wxt.config.firefox.ts",
    "zip:edge": "wxt zip -b edge -c wxt.config.edge.ts",
    "zip:all": "bun run --parallel zip zip:firefox zip:edge",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/svelte": "^5.0.8",
    "@wxt-dev/module-svelte": "^2.0.4",
    "daisyui": "^5.6.18",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.27"
  },
  "lint-staged": {
    "*.{ts,svelte,html,css}": [
      "prettier --write"
    ]
  }
}
